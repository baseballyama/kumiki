{
  "name": "@kumiki/attachment-combobox",
  "version": "0.0.0",
  "description": "Svelte 5 attachments (Layer 3) for combobox — reactive bindings to @kumiki/machines/combobox.",
  "homepage": "https://github.com/baseballyama/kumiki/tree/main/packages/components/combobox/attachment",
  "bugs": "https://github.com/baseballyama/kumiki/issues",
  "license": "MIT",
  "author": "Yuichiro Yamashita",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/baseballyama/kumiki.git",
    "directory": "packages/components/combobox/attachment"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./with-validation": {
      "types": "./dist/with-validation/index.d.mts",
      "import": "./dist/with-validation/index.mjs"
    },
    "./with-async-search": {
      "types": "./dist/with-async-search/index.d.mts",
      "import": "./dist/with-async-search/index.mjs"
    },
    "./with-multi-select": {
      "types": "./dist/with-multi-select/index.d.mts",
      "import": "./dist/with-multi-select/index.mjs"
    },
    "./with-virtualization": {
      "types": "./dist/with-virtualization/index.d.mts",
      "import": "./dist/with-virtualization/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src",
    "size": "size-limit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@kumiki/machines": "workspace:*",
    "@kumiki/primitives": "workspace:*",
    "@kumiki/runtime": "workspace:*"
  },
  "devDependencies": {
    "@size-limit/preset-small-lib": "catalog:",
    "jsdom": "catalog:",
    "size-limit": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "svelte": "catalog:"
  },
  "size-limit": [
    {
      "name": "attachment-combobox (incremental)",
      "path": "dist/index.mjs",
      "limit": "1650 B",
      "ignore": [
        "@kumiki/runtime",
        "@kumiki/primitives",
        "@kumiki/machines"
      ]
    },
    {
      "name": "attachment-combobox (full first-import)",
      "path": "dist/index.mjs",
      "limit": "3250 B"
    },
    {
      "name": "with-validation (incremental, base excluded)",
      "path": "dist/with-validation/index.mjs",
      "limit": "750 B",
      "ignore": [
        "@kumiki/runtime",
        "@kumiki/primitives",
        "@kumiki/machines",
        "@kumiki/attachment-combobox"
      ]
    },
    {
      "name": "with-async-search (incremental, base excluded)",
      "path": "dist/with-async-search/index.mjs",
      "limit": "750 B",
      "ignore": [
        "@kumiki/runtime",
        "@kumiki/primitives",
        "@kumiki/machines",
        "@kumiki/attachment-combobox"
      ]
    },
    {
      "name": "with-multi-select (incremental, base excluded)",
      "path": "dist/with-multi-select/index.mjs",
      "limit": "750 B",
      "ignore": [
        "@kumiki/runtime",
        "@kumiki/primitives",
        "@kumiki/machines",
        "@kumiki/attachment-combobox"
      ]
    },
    {
      "name": "with-virtualization (incremental, base excluded)",
      "path": "dist/with-virtualization/index.mjs",
      "limit": "750 B",
      "ignore": [
        "@kumiki/runtime",
        "@kumiki/primitives",
        "@kumiki/machines",
        "@kumiki/attachment-combobox"
      ]
    }
  ]
}
