{
  "name": "@kumiki/machine-accordion",
  "version": "0.0.0",
  "description": "Pure-TS finite state machine for the accordion component.",
  "homepage": "https://github.com/baseballyama/kumiki/tree/main/packages/components/accordion/machine",
  "bugs": "https://github.com/baseballyama/kumiki/issues",
  "license": "MIT",
  "author": "Yuichiro Yamashita",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/baseballyama/kumiki.git",
    "directory": "packages/components/accordion/machine"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src",
    "size": "size-limit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@kumiki/primitives": "workspace:*",
    "@kumiki/runtime": "workspace:*"
  },
  "devDependencies": {
    "@size-limit/preset-small-lib": "catalog:",
    "size-limit": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "size-limit": [
    {
      "name": "machine-accordion",
      "path": "dist/index.mjs",
      "limit": "1700 B"
    }
  ]
}
