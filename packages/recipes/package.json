{
  "name": "@kumiki/recipes",
  "version": "0.0.0-preview.0",
  "description": "Layer 5 preview — opinionated, styled recipe templates built on top of @kumiki/components. Ships under the `preview` dist-tag during the v1.0 series.",
  "homepage": "https://github.com/baseballyama/kumiki/tree/main/packages/recipes",
  "bugs": "https://github.com/baseballyama/kumiki/issues",
  "license": "MIT",
  "author": "Yuichiro Yamashita",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/baseballyama/kumiki.git",
    "directory": "packages/recipes"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "svelte": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json",
    "./toggle": {
      "types": "./dist/toggle/index.d.ts",
      "svelte": "./dist/toggle/index.js",
      "import": "./dist/toggle/index.js"
    },
    "./dialog": {
      "types": "./dist/dialog/index.d.ts",
      "svelte": "./dist/dialog/index.js",
      "import": "./dist/dialog/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "tag": "preview"
  },
  "scripts": {
    "build": "svelte-package -i src -o dist && publint",
    "dev": "svelte-package -i src -o dist --watch",
    "test": "vitest run --passWithNoTests",
    "typecheck": "svelte-check --tsconfig ./tsconfig.json",
    "lint": "oxlint src",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@kumiki/components": "workspace:*"
  },
  "devDependencies": {
    "@sveltejs/package": "catalog:",
    "@sveltejs/vite-plugin-svelte": "catalog:",
    "publint": "catalog:",
    "svelte": "catalog:",
    "svelte-check": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "svelte": "catalog:"
  }
}
