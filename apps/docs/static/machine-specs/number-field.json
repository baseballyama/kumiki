{
  "id": "numberField",
  "initial": "idle",
  "context": {
    "value": null,
    "min": null,
    "max": null,
    "step": 1,
    "pageStep": 10
  },
  "states": {
    "idle": {
      "on": {
        "INCREMENT": {
          "actions": ["increment"]
        },
        "DECREMENT": {
          "actions": ["decrement"]
        },
        "PAGE_INCREMENT": {
          "actions": ["pageIncrement"]
        },
        "PAGE_DECREMENT": {
          "actions": ["pageDecrement"]
        },
        "TO_MIN": {
          "actions": ["toMin"]
        },
        "TO_MAX": {
          "actions": ["toMax"]
        },
        "CLEAR": {
          "actions": ["clear"]
        },
        "SET.VALUE": {
          "actions": ["setValue"]
        },
        "SET.MIN": {
          "actions": ["setMin"]
        },
        "SET.MAX": {
          "actions": ["setMax"]
        },
        "SET.STEP": {
          "actions": ["setStep"]
        },
        "SET.PAGE_STEP": {
          "actions": ["setPageStep"]
        },
        "DISABLE": {
          "target": "disabled"
        }
      }
    },
    "disabled": {
      "on": {
        "ENABLE": {
          "target": "idle"
        }
      }
    }
  }
}
