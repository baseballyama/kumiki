        },
        "BLUR": {
          "actions": ["blur"]
        },
        "NAVIGATE": {
          "actions": ["navigate"]
        },
        "SET.ITEMS": {
          "actions": ["setItems"]
        },
        "SET.VALUE": {
          "actions": ["setValue"]
        },
        "SET.MODE": {
          "actions": ["setMode"]
        },
        "SET.COLLAPSIBLE": {
          "actions": ["setCollapsible"]
        }
      }
    }
  }
