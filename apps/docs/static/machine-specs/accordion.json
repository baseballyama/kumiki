{
  "id": "accordion",
  "initial": "idle",
  "context": {
    "items": [
      {
        "id": "one",
        "value": "one"
      },
      {
        "id": "two",
        "value": "two"
      }
    ],
    "expandedIds": [],
    "focusedId": null,
    "mode": "single",
    "collapsible": true
  },
  "states": {
    "idle": {
      "on": {
        "TOGGLE": {
          "actions": ["toggle"]
        },
        "EXPAND": {
          "actions": ["expand"]
        },
        "COLLAPSE": {
          "actions": ["collapse"]
        },
        "FOCUS": {
