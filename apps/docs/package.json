{
  "name": "@kumiki/docs",
  "version": "0.0.0",
  "private": true,
  "description": "Kumiki documentation site (SvelteKit, deployed to Cloudflare Pages).",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "prebuild": "node scripts/build-llms-full.mjs && node scripts/build-sizes.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "test:e2e": "playwright test",
    "test:a11y": "playwright test --project=a11y",
    "test:sr": "playwright test --project=screen-reader",
    "typecheck": "svelte-check --tsconfig ./tsconfig.json",
    "lint": "oxlint src"
  },
  "dependencies": {
    "@kumiki/attachment-checkbox": "workspace:*",
    "@kumiki/attachment-combobox": "workspace:*",
    "@kumiki/attachment-radio-group": "workspace:*",
    "@kumiki/attachment-switch": "workspace:*",
    "@kumiki/attachment-toggle": "workspace:*",
    "@kumiki/component-accordion": "workspace:*",
    "@kumiki/component-checkbox": "workspace:*",
    "@kumiki/component-combobox": "workspace:*",
    "@kumiki/component-dialog": "workspace:*",
    "@kumiki/component-form-field": "workspace:*",
    "@kumiki/component-number-field": "workspace:*",
    "@kumiki/component-popover": "workspace:*",
    "@kumiki/component-radio-group": "workspace:*",
    "@kumiki/component-select": "workspace:*",
    "@kumiki/component-slider": "workspace:*",
    "@kumiki/component-switch": "workspace:*",
    "@kumiki/component-tabs": "workspace:*",
    "@kumiki/component-toggle": "workspace:*",
    "@kumiki/component-tooltip": "workspace:*",
    "@kumiki/locale": "workspace:*",
    "@kumiki/primitives": "workspace:*"
  },
  "devDependencies": {
    "@axe-core/playwright": "catalog:",
    "@guidepup/guidepup": "catalog:",
    "@guidepup/playwright": "catalog:",
    "@playwright/test": "catalog:",
    "@sveltejs/adapter-cloudflare": "catalog:",
    "@sveltejs/kit": "catalog:",
    "@sveltejs/vite-plugin-svelte": "catalog:",
    "@types/node": "^22.10.0",
    "axe-core": "catalog:",
    "playwright": "catalog:",
    "svelte": "catalog:",
    "svelte-check": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:"
  }
}
